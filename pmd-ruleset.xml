<?xml version="1.0"?>
<ruleset name="KSeF SDK PMD Rules"
         xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.sourceforge.io/ruleset_2_0_0.xsd">

    <description>PMD ruleset for KSeF Java SDK hand-written code</description>

    <rule ref="category/java/bestpractices.xml">
        <exclude name="GuardLogStatement"/>
        <!-- char[] params for passwords/keys are standard Java security API convention -->
        <exclude name="UseVarargs"/>
        <!-- AES key + IV are package-internal crypto material; defensive copy adds noise without security gain. -->
        <exclude name="ArrayIsStoredDirectly"/>
        <!-- Exception unwrapping pattern wraps non-runtime causes; PMD's stack-trace heuristic is too narrow. -->
        <exclude name="PreserveStackTrace"/>
        <!-- Compact constructor parameter reassignment is the canonical record validation pattern. -->
        <exclude name="UnusedAssignment"/>
    </rule>

    <rule ref="category/java/codestyle.xml">
        <exclude name="AtLeastOneConstructor"/>
        <exclude name="OnlyOneReturn"/>
        <exclude name="CommentDefaultAccessModifier"/>
        <exclude name="DefaultPackage"/>
        <exclude name="CallSuperInConstructor"/>
        <exclude name="LongVariable"/>
        <exclude name="ShortVariable"/>
        <exclude name="ShortClassName"/>
        <exclude name="ShortMethodName"/>
        <exclude name="TooManyStaticImports"/>
        <exclude name="LocalVariableCouldBeFinal"/>
        <exclude name="MethodArgumentCouldBeFinal"/>
        <!-- var-keyword usage is idiomatic in modern Java; we use it where readability improves. -->
        <exclude name="UseExplicitTypes"/>
        <!-- Underscores in numeric literals: optional readability — we already use them where helpful. -->
        <exclude name="UseUnderscoresInNumericLiterals"/>
        <!-- Style preference; switch with two cases is fine. -->
        <exclude name="TooFewBranchesForSwitch"/>
        <!-- Generated import refs sometimes require fully-qualified names to disambiguate. -->
        <exclude name="UnnecessaryFullyQualifiedName"/>
        <!-- LinguisticNaming flags semantic naming we use intentionally (e.g. 'is...' returning enums). -->
        <exclude name="LinguisticNaming"/>
    </rule>

    <rule ref="category/java/design.xml">
        <exclude name="LawOfDemeter"/>
        <exclude name="LoosePackageCoupling"/>
        <exclude name="TooManyMethods"/>
        <exclude name="ExcessiveImports"/>
        <exclude name="AvoidCatchingGenericException"/>
        <exclude name="CognitiveComplexity"/>
        <exclude name="CyclomaticComplexity"/>
        <exclude name="CouplingBetweenObjects"/>
        <!-- Java records are intentional data classes — flagging them is a false positive. -->
        <exclude name="DataClass"/>
        <!-- NPathComplexity overlaps with cognitive/cyclomatic; same justification as those exclusions. -->
        <exclude name="NPathComplexity"/>
        <!-- KsefClient is the SDK facade: aggregating 11 domain clients is its purpose. -->
        <exclude name="GodClass"/>
        <!-- Exception translation (catch + wrap in domain exception type) is the
             recommended pattern; PMD's heuristic mistakes it for flow control. -->
        <exclude name="ExceptionAsFlowControl"/>
    </rule>

    <!-- Coupling threshold raised to 80: domain clients importing many generated model types
         is inherent to an API client SDK; KsefClient as the facade aggregates 11 domains and
         the InvoicingMappers class collects all invoicing record + builder mappings. -->
    <rule ref="category/java/design.xml/CouplingBetweenObjects">
        <properties>
            <property name="threshold" value="80"/>
        </properties>
    </rule>

    <!-- Complexity thresholds: default 15 is too tight for retry/handler patterns -->
    <rule ref="category/java/design.xml/CognitiveComplexity">
        <properties>
            <property name="reportLevel" value="20"/>
        </properties>
    </rule>
    <rule ref="category/java/design.xml/CyclomaticComplexity">
        <properties>
            <property name="methodReportLevel" value="20"/>
        </properties>
    </rule>

    <rule ref="category/java/errorprone.xml">
        <!-- Java records use field-name accessors (record.baseUrl() returns field baseUrl).
             SDK follows the same convention for non-record classes. -->
        <exclude name="AvoidFieldNameMatchingMethodName"/>
        <!-- Lazy-init and explicit clearing of references uses null assignment intentionally. -->
        <exclude name="NullAssignment"/>
        <!-- Reflection-only test scaffolding classes don't always carry @Test methods. -->
        <exclude name="TestClassWithoutTestCases"/>
        <!-- instanceof-in-catch is the idiomatic way to differentiate I/O vs runtime failures. -->
        <exclude name="AvoidInstanceofChecksInCatchClause"/>
    </rule>

    <rule ref="category/java/multithreading.xml">
        <!-- DoNotUseThreads is a J2EE/webapp rule. This is a standalone SDK. -->
        <exclude name="DoNotUseThreads"/>
        <!-- AvoidUsingVolatile: volatile boolean for close-guard is standard pattern. -->
        <exclude name="AvoidUsingVolatile"/>
        <!-- synchronized methods on KsefClient are intentional — guards single-flight auth. -->
        <exclude name="AvoidSynchronizedAtMethodLevel"/>
        <!-- UseConcurrentHashMap is overly aggressive: it flags every HashMap usage,
             including single-threaded local maps. SDK records use HashMap for short-lived
             local state; concurrent variants would be a cargo-cult anti-pattern here. -->
        <exclude name="UseConcurrentHashMap"/>
    </rule>

    <rule ref="category/java/performance.xml">
        <!-- Exception wrapping in retry loops requires object creation in catch blocks. -->
        <exclude name="AvoidInstantiatingObjectsInLoops"/>
        <!-- TooFewBranchesForSwitch: switch on enums with two cases is the cleanest expression. -->
        <exclude name="TooFewBranchesForSwitch"/>
    </rule>

    <!-- Short variable names: replaces the stock ShortVariable with an XPath
         rule that exempts domain-meaningful abbreviations:
         - raw: OpenAPI generated *Raw type instances (idiomatic SDK plumbing)
         - nip / NIP / VAT: Polish tax IDs and KSeF identifier types
         - id / pkg / url / out / obj / o / csr / zip / upo: standard short names
         - FA2 / FA3 / ROZ / KOR / JST / ZAL / UPR: KSeF schema/role codes -->
    <rule name="ShortVariableWithDomainExceptions"
          language="java"
          message="Avoid variables with short names like {0}"
          class="net.sourceforge.pmd.lang.rule.xpath.XPathRule">
        <description>Variables with very short names should be avoided unless
        they are well-known domain abbreviations.</description>
        <priority>3</priority>
        <properties>
            <property name="xpath">
                <value>
<![CDATA[
//VariableId[
    string-length(@Name) < 4
    and not(@Name = ('raw','nip','NIP','VAT','id','pkg','url','out','obj','o',
                     'csr','zip','upo','FA2','FA3','ROZ','KOR','JST','ZAL','UPR'))
    and not(../../ForStatement)
    and not(../../ForInit)
    and not(../../CatchParameter)
    and not(../../LambdaExpression)
    and not(../../FormalParameter[parent::FormalParameters[parent::CatchClause]])
]
]]>
                </value>
            </property>
        </properties>
    </rule>

</ruleset>
